{
  "version": "1.0",
  "tax_rate": 0.25,
  "cost_methods": ["SPECIFIC_ID", "FIFO"],
  "entry_templates": {
    "DOWN": {
      "label": "顺流交易（母→子）",
      "description": "未实现利润全部归属于母公司股东，不涉及少数股东分摊",
      "entries": [
        {
          "dr": "营业收入",
          "cr": null,
          "amount_formula": "revenue * unsold_ratio",
          "note": "冲减内部销售收入"
        },
        {
          "dr": null,
          "cr": "营业成本",
          "amount_formula": "revenue * unsold_ratio - unrealized_profit",
          "note": "倒挤营业成本"
        },
        {
          "dr": null,
          "cr": "存货",
          "amount_formula": "unrealized_profit",
          "note": "冲减存货至原销售方成本"
        },
        {
          "dr": "递延所得税资产",
          "cr": null,
          "amount_formula": "unrealized_profit * tax_rate",
